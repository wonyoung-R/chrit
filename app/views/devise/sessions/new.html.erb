<div class="min-h-screen bg-black text-white flex flex-col relative overflow-hidden">
  
  <!-- Background Effects -->
  <div class="absolute inset-0 bg-gradient-to-br from-purple-900/20 via-black to-blue-900/20"></div>
  <div class="absolute inset-0">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-purple-600/10 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
  </div>
  
  <!-- Navigation -->
  <nav class="relative z-10 flex justify-between items-center p-8">
    <%= link_to root_path, class: "text-2xl font-bold bg-gradient-to-r from-purple-400 to-blue-400 bg-clip-text text-transparent" do %>
      Chrit
    <% end %>
    <%= link_to "Home", root_path, class: "text-sm text-gray-400 hover:text-white transition duration-200" %>
  </nav>
  
  <!-- Login Form -->
  <div class="flex-1 flex items-center justify-center px-4 relative z-10">
    <div class="w-full max-w-md">
      
      <!-- Form Card -->
      <div class="bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-2xl p-8">
        <h2 class="text-3xl font-bold mb-2 bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent">
          Sign In
        </h2>
        <p class="text-gray-400 mb-8">Continue saving your knowledge</p>
        
        <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          <div class="space-y-6">
            <!-- Email Field -->
            <div>
              <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-400 mb-2" %>
              <div class="relative group">
                <div class="absolute inset-0 bg-gradient-to-r from-purple-600/20 to-blue-600/20 rounded-xl blur-md opacity-0 group-hover:opacity-100 transition duration-300"></div>
                <%= f.email_field :email, 
                    autofocus: true, 
                    autocomplete: "email",
                    placeholder: "your@email.com",
                    class: "relative w-full px-4 py-3 bg-gray-900/90 backdrop-blur-sm border border-gray-800 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-purple-500/50 transition-all duration-300" %>
              </div>
            </div>
            
            <!-- Password Field -->
            <div>
              <%= f.label :password, "Password", class: "block text-sm font-medium text-gray-400 mb-2" %>
              <div class="relative group">
                <div class="absolute inset-0 bg-gradient-to-r from-purple-600/20 to-blue-600/20 rounded-xl blur-md opacity-0 group-hover:opacity-100 transition duration-300"></div>
                <%= f.password_field :password, 
                    autocomplete: "current-password",
                    placeholder: "••••••••",
                    class: "relative w-full px-4 py-3 bg-gray-900/90 backdrop-blur-sm border border-gray-800 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-purple-500/50 transition-all duration-300" %>
              </div>
            </div>
            
            <!-- Remember Me -->
            <% if devise_mapping.rememberable? %>
              <div class="flex items-center">
                <%= f.check_box :remember_me, class: "w-4 h-4 bg-gray-900 border-gray-700 rounded focus:ring-purple-500 focus:ring-2" %>
                <%= f.label :remember_me, "Remember me", class: "ml-2 text-sm text-gray-400" %>
              </div>
            <% end %>
            
            <!-- Submit Button -->
            <div>
              <%= f.submit "Sign In", 
                  class: "w-full px-6 py-3 bg-gradient-to-r from-purple-600 to-blue-600 text-white rounded-xl hover:from-purple-700 hover:to-blue-700 transition duration-200 font-medium cursor-pointer" %>
            </div>
          </div>
        <% end %>
        
        <!-- Links -->
        <div class="mt-6 text-center space-y-2">
          <%= link_to "Don't have an account?", new_registration_path(resource_name), 
              class: "text-sm text-gray-400 hover:text-purple-400 transition duration-200" %>
          <br>
          <%= link_to "Forgot your password?", new_password_path(resource_name), 
              class: "text-sm text-gray-400 hover:text-purple-400 transition duration-200" %>
        </div>
      </div>
      
    </div>
  </div>
</div>
