<div class="min-h-screen bg-black text-white flex flex-col relative overflow-hidden">
  
  <!-- Background Effects -->
  <div class="absolute inset-0 bg-gradient-to-br from-purple-900/20 via-black to-blue-900/20"></div>
  <div class="absolute inset-0">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-purple-600/10 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
  </div>
  
  <!-- Navigation -->
  <nav class="relative z-10 flex justify-between items-center p-8">
    <%= link_to root_path, class: "text-2xl font-bold bg-gradient-to-r from-purple-400 to-blue-400 bg-clip-text text-transparent" do %>
      Chrit
    <% end %>
    <div>
      <% if user_signed_in? %>
        <div class="flex items-center gap-6">
          <%= link_to "Pricing", pricing_path, class: "text-sm text-gray-400 hover:text-white transition duration-200" %>
          <span class="text-sm text-gray-400"><%= current_user.email %></span>
          <%= link_to "Sign out", destroy_user_session_path,
              class: "text-sm text-gray-400 hover:text-white transition duration-200",
              data: { turbo_method: :delete } %>
        </div>
      <% else %>
        <div class="flex gap-4">
          <%= link_to "Pricing", pricing_path, class: "px-4 py-2 text-sm text-gray-400 hover:text-white transition duration-200" %>
          <%= link_to "Sign in", new_user_session_path,
              class: "px-4 py-2 text-sm text-white hover:text-gray-300 transition duration-200" %>
          <%= link_to "Get Started", new_user_registration_path,
              class: "px-4 py-2 text-sm bg-gradient-to-r from-purple-600 to-blue-600 rounded-lg hover:from-purple-700 hover:to-blue-700 transition duration-200" %>
        </div>
      <% end %>
    </div>
  </nav>
  
  <!-- Main Content -->
  <div class="flex-1 relative z-10">
    <div class="max-w-7xl mx-auto px-8">
      
      <!-- Dashboard Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent">
          Dashboard
        </h1>
        <p class="text-gray-400 mt-2">Manage and explore your saved knowledge</p>
      </div>
      
      <% if user_signed_in? %>
        <!-- Main Layout Container -->
        <div class="flex gap-6">
          
          <!-- Left Column - Stats & Search -->
          <div class="w-80 flex-shrink-0">
            
            <!-- Stats Card -->
            <div class="bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-xl p-6 mb-6 shadow-sm">
              <h2 class="text-lg font-semibold text-white mb-4">Statistics</h2>
              
              <div class="space-y-4">
                <div class="flex justify-between items-center">
                  <span class="text-gray-400 text-sm">Total Saved</span>
                  <span class="text-2xl font-bold bg-gradient-to-r from-purple-400 to-blue-400 bg-clip-text text-transparent">
                    <%= @total_knowledges %>
                  </span>
                </div>
                
                <div class="flex justify-between items-center">
                  <span class="text-gray-400 text-sm">YouTube</span>
                  <span class="text-xl font-bold text-white">
                    <%= @youtube_count %>
                  </span>
                </div>
                
                <div class="flex justify-between items-center">
                  <span class="text-gray-400 text-sm">Articles</span>
                  <span class="text-xl font-bold text-white">
                    <%= @article_count %>
                  </span>
                </div>
                
                <div class="border-t border-gray-800 pt-4">
                  <div class="flex justify-between items-center">
                    <span class="text-gray-400 text-sm">This Month</span>
                    <span class="text-xl font-bold text-green-400">
                      <%= @this_month_count %>
                    </span>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Quick Search -->
            <div class="bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-xl p-6 shadow-sm">
              <h2 class="text-lg font-semibold text-white mb-6 text-center">Quick Search</h2>
              
              <div class="space-y-3">
                <input type="text" 
                       id="search-input"
                       placeholder="Enter search term..." 
                       class="w-full px-8 py-4 mb-3 text-base bg-gray-900/90 backdrop-blur-sm border border-gray-800 rounded-2xl text-white placeholder-gray-500 focus:outline-none focus:border-purple-500/50 transition-all duration-300">
                <button class="w-full inline-flex items-center justify-center h-12 px-12 mb-6 bg-gradient-to-r from-purple-600 to-blue-600 text-white rounded-full text-base font-medium transition-all duration-200 shadow-sm hover:from-purple-700 hover:to-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-purple-500/50">
                  Search
                </button>
              </div>
              
              <!-- Type Filter Tags -->
              <div class="mb-5 mt-5">
                <div class="text-sm text-gray-400 mb-4 text-center">Content Type</div>
                <div class="flex flex-wrap gap-2 justify-center mb-6" id="content-type-buttons">
                  <button data-type="all" class="content-type-btn inline-flex items-center justify-center h-10 px-6 bg-gradient-to-r from-purple-600 to-blue-600 text-white rounded-full text-sm font-medium transition-all duration-200 shadow-sm hover:from-purple-700 hover:to-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-purple-500/50 active">
                    ALL
                  </button>
                  <button data-type="youtube" class="content-type-btn inline-flex items-center justify-center h-10 px-6 bg-gray-800/50 backdrop-blur-sm border border-gray-700 text-gray-400 rounded-full text-sm font-medium hover:bg-gray-800/70 hover:text-white hover:border-gray-600 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-500/50">
                    YouTube
                  </button>
                  <button data-type="thread" class="content-type-btn inline-flex items-center justify-center h-10 px-6 bg-gray-800/50 backdrop-blur-sm border border-gray-700 text-gray-400 rounded-full text-sm font-medium hover:bg-gray-800/70 hover:text-white hover:border-gray-600 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-500/50">
                    Thread
                  </button>
                  <button data-type="article" class="content-type-btn inline-flex items-center justify-center h-10 px-6 bg-gray-800/50 backdrop-blur-sm border border-gray-700 text-gray-400 rounded-full text-sm font-medium hover:bg-gray-800/70 hover:text-white hover:border-gray-600 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-500/50">
                    Article
                  </button>
                </div>
              </div>
              
              <!-- Popular Tags -->
              <div class="space-y-4 mt-5">
                <div class="text-sm text-gray-400 text-center">Popular Tags</div>
                <div class="flex flex-wrap gap-1 justify-center">
                  <% if @popular_tags && @popular_tags.any? %>
                    <% @popular_tags.each do |tag| %>
                      <span class="text-xs text-white/80 hover:text-white cursor-pointer transition-all duration-200">
                        #<%= tag.name %>
                      </span>
                    <% end %>
                  <% else %>
                    <span class="text-xs text-white/80 hover:text-white cursor-pointer transition-all duration-200">
                      #politics
                    </span>
                    <span class="text-xs text-white/80 hover:text-white cursor-pointer transition-all duration-200">
                      #technology
                    </span>
                    <span class="text-xs text-white/80 hover:text-white cursor-pointer transition-all duration-200">
                      #economy
                    </span>
                    <span class="text-xs text-white/80 hover:text-white cursor-pointer transition-all duration-200">
                      #society
                    </span>
                    <span class="text-xs text-white/80 hover:text-white cursor-pointer transition-all duration-200">
                      #culture
                    </span>
                  <% end %>
                </div>
              </div>
            </div>
            
          </div>
          
          <!-- Right Column - Knowledge List -->
          <div class="flex-1">
            
            <!-- List Header -->
            <div class="flex justify-between items-center mb-4">
              <h2 class="text-lg font-semibold text-white">Saved Knowledge</h2>
              <div class="flex gap-2">
                <button class="inline-flex items-center justify-center h-8 px-3 bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-md text-sm font-medium text-gray-400 hover:text-white hover:border-gray-700 hover:bg-gray-800/70 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-500/50">
                  Latest
                </button>
                <button class="inline-flex items-center justify-center h-8 px-3 bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-md text-sm font-medium text-gray-400 hover:text-white hover:border-gray-700 hover:bg-gray-800/70 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-500/50">
                  Oldest
                </button>
                <button class="inline-flex items-center justify-center h-8 px-3 bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-md text-sm font-medium text-gray-400 hover:text-white hover:border-gray-700 hover:bg-gray-800/70 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-500/50">
                  Popular
                </button>
              </div>
            </div>
            
            <!-- Knowledge Grid -->
            <div class="grid gap-4">
              <% if @recent_knowledges.any? %>
                <%= turbo_frame_tag "knowledges" do %>
                  <% @recent_knowledges.each do |knowledge| %>
                    <%= link_to knowledge_path(knowledge),
                        class: "bg-gray-900/30 backdrop-blur-sm border border-gray-800 rounded-xl p-6 shadow-sm
                               hover:bg-gray-900/50 hover:border-purple-500/30 transition-all duration-200 block",
                        data: { turbo_frame: "_top" } do %>
                      
                      <div class="flex items-start justify-between">
                        <!-- Content -->
                        <div class="flex-1 min-w-0">
                          <div class="flex items-center gap-3 mb-2">
                            <!-- Type Badge -->
                            <% if knowledge.content_type == 'youtube' %>
                              <span class="content-type-badge inline-flex items-center justify-center h-8 px-4 backdrop-blur-sm rounded-full text-xs font-medium transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-500/50 bg-gradient-to-r from-red-600 to-red-500 text-white hover:from-red-700 hover:to-red-600">
                                YouTube
                              </span>
                            <% elsif knowledge.content_type == 'thread' %>
                              <span class="content-type-badge inline-flex items-center justify-center h-8 px-4 backdrop-blur-sm rounded-full text-xs font-medium transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-500/50 bg-gradient-to-r from-green-600 to-green-500 text-white hover:from-green-700 hover:to-green-600">
                                Thread
                              </span>
                            <% else %>
                              <span class="content-type-badge inline-flex items-center justify-center h-8 px-4 backdrop-blur-sm rounded-full text-xs font-medium transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-500/50 bg-gradient-to-r from-blue-600 to-blue-500 text-white hover:from-blue-700 hover:to-blue-600">
                                Article
                              </span>
                            <% end %>
                            <!-- Date -->
                            <span class="text-xs text-gray-500">
                              <% if knowledge.content_type == 'youtube' && knowledge.published_at.present? %>
                                <%= time_ago_in_words(knowledge.published_at) %> ago published
                              <% else %>
                                <%= time_ago_in_words(knowledge.created_at) %> ago saved
                              <% end %>
                            </span>
                          </div>
                          
                          <h3 class="text-white font-medium text-lg mb-2">
                            <%= knowledge.title || "Processing..." %>
                          </h3>
                          
                          <% if knowledge.summary.present? %>
                            <p class="text-gray-400 text-sm mb-3 line-clamp-2">
                              <%= knowledge.summary %>
                            </p>
                          <% end %>
                          
                          <% if knowledge.keywords.present? %>
                            <div class="flex flex-wrap gap-2">
                              <% JSON.parse(knowledge.keywords).first(5).each do |keyword| %>
                                <span class="px-3 py-1 bg-purple-500/10 rounded-full text-xs text-white cursor-pointer hover:bg-purple-500/20 transition-all duration-200">
                                  <%= keyword %>
                                </span>
                              <% end %>
                            </div>
                          <% end %>
                        </div>
                        
                        <!-- Status/Action -->
                        <div class="ml-4 flex-shrink-0">
                          <% if knowledge.processing? %>
                            <div class="animate-spin h-5 w-5 border-2 border-purple-500 rounded-full border-t-transparent"></div>
                          <% else %>
                            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                          <% end %>
                        </div>
                      </div>
                      
                    <% end %>
                  <% end %>
                <% end %>
              <% else %>
                <div class="bg-gray-900/30 backdrop-blur-sm border border-gray-800 rounded-xl p-12 text-center">
                  <div class="text-6xl mb-4">📚</div>
                  <h3 class="text-xl font-semibold text-white mb-2">No saved knowledge yet</h3>
                  <p class="text-gray-400 mb-6">Enter a URL to save your first knowledge</p>
                  <%= link_to "Save Knowledge", root_path, class: "inline-block px-6 py-3 bg-gradient-to-r from-purple-600 to-blue-600 text-white rounded-xl hover:from-purple-700 hover:to-blue-700 transition duration-200 font-medium" %>
                </div>
              <% end %>
            </div>
            
            <!-- Pagination -->
            <% if @recent_knowledges.any? && @total_knowledges > 10 %>
              <div class="flex justify-center gap-2 mt-8">
                <button class="inline-flex items-center justify-center h-9 px-4 bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-md text-sm font-medium text-gray-400 hover:text-white hover:border-gray-700 hover:bg-gray-800/70 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-500/50">
                  Previous
                </button>
                <button class="inline-flex items-center justify-center h-9 px-4 bg-purple-900/50 border border-purple-500/50 rounded-md text-sm font-medium text-purple-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-purple-500/50">
                  1
                </button>
                <button class="inline-flex items-center justify-center h-9 px-4 bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-md text-sm font-medium text-gray-400 hover:text-white hover:border-gray-700 hover:bg-gray-800/70 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-500/50">
                  2
                </button>
                <button class="inline-flex items-center justify-center h-9 px-4 bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-md text-sm font-medium text-gray-400 hover:text-white hover:border-gray-700 hover:bg-gray-800/70 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-500/50">
                  3
                </button>
                <button class="inline-flex items-center justify-center h-9 px-4 bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-md text-sm font-medium text-gray-400 hover:text-white hover:border-gray-700 hover:bg-gray-800/70 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-500/50">
                  Next
                </button>
              </div>
            <% end %>
            
          </div>
          
        </div>
        
      <% else %>
        <!-- Not Logged In Redirect -->
        <script>
          window.location.href = '<%= new_user_session_path %>';
        </script>
      <% end %>
      
    </div>
  </div>
  
  <!-- JavaScript for interactive content type buttons -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const contentTypeButtons = document.querySelectorAll('.content-type-btn');
      
      contentTypeButtons.forEach(button => {
        button.addEventListener('click', function() {
          // Remove active state from all buttons
          contentTypeButtons.forEach(btn => {
            btn.classList.remove('bg-gradient-to-r', 'from-purple-600', 'to-blue-600', 'text-white', 'hover:from-purple-700', 'hover:to-blue-700');
            btn.classList.add('bg-gray-800/50', 'border', 'border-gray-700', 'text-gray-400', 'hover:bg-gray-800/70', 'hover:text-white', 'hover:border-gray-600');
          });
          
          // Add active state to clicked button
          this.classList.remove('bg-gray-800/50', 'border', 'border-gray-700', 'text-gray-400', 'hover:bg-gray-800/70', 'hover:text-white', 'hover:border-gray-600');
          this.classList.add('bg-gradient-to-r', 'from-purple-600', 'to-blue-600', 'text-white', 'hover:from-purple-700', 'hover:to-blue-700');
          
          // You can add filtering logic here based on the data-type attribute
          const selectedType = this.getAttribute('data-type');
          console.log('Selected content type:', selectedType);
        });
      });
    });
  </script>
  
</div>