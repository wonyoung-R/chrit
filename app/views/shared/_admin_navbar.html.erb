<!-- Navigation -->
<nav class="relative z-10 flex justify-between items-center p-8 bg-gray-900 border-b border-gray-700">
  <%= link_to root_path, class: "text-2xl font-bold bg-gradient-to-r from-purple-400 to-blue-400 bg-clip-text text-transparent" do %>
    Chrit
  <% end %>
  <div>
    <div class="flex gap-4">
      <%= link_to "대시보드", dashboard_path, class: "px-4 py-2 text-sm text-gray-400 hover:text-white transition duration-200" %>
      <%= link_to "가격", pricing_path, class: "px-4 py-2 text-sm text-gray-400 hover:text-white transition duration-200" %>
      <%= link_to "관리자", admin_dashboard_path, class: "px-4 py-2 text-sm text-purple-400 hover:text-purple-300 transition duration-200" %>
      <%= link_to "로그아웃", destroy_user_session_path, class: "px-4 py-2 text-sm text-gray-400 hover:text-white transition duration-200", data: { turbo_method: :delete } %>
    </div>
  </div>
</nav>

