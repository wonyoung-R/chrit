<div class="min-h-screen bg-black text-white flex flex-col relative overflow-hidden">
  
  <!-- Background Effects -->
  <div class="absolute inset-0 bg-gradient-to-br from-purple-900/20 via-black to-blue-900/20"></div>
  <div class="absolute inset-0">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-purple-600/10 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
  </div>
  
  <!-- Navigation -->
  <nav class="relative z-10 flex justify-between items-center p-8">
    <%= link_to "← Back", root_path, class: "text-sm text-gray-400 hover:text-white transition duration-200" %>
    <div class="text-2xl font-bold bg-gradient-to-r from-purple-400 to-blue-400 bg-clip-text text-transparent">
      Chrit
    </div>
    <div class="w-20"></div>
  </nav>
  
  <!-- Content -->
  <div class="flex-1 flex items-start justify-center px-4 pb-8 relative z-10">
    <div class="w-full max-w-4xl">
      <div class="bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-2xl p-8">
        <% if @knowledge.completed? %>
          <!-- Title -->
          <h1 class="text-3xl font-bold bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent mb-6">
            <%= @knowledge.title %>
          </h1>
        
          <!-- Meta Information -->
          <div class="flex items-center gap-4 text-sm text-gray-400 mb-6">
            <span class="flex items-center gap-1">
              <%= @knowledge.content_type == "youtube" ? "🎥" : "📄" %>
              <span><%= @knowledge.content_type == "youtube" ? "YouTube" : "Article" %></span>
            </span>
            <span class="flex items-center gap-1">
              📅 <%= @knowledge.created_at.strftime("%Y-%m-%d") %>
            </span>
            <% if @knowledge.duration %>
              <span class="flex items-center gap-1">
                ⏱️ <%= format_duration(@knowledge.duration) %>
              </span>
            <% end %>
          </div>
          
          <!-- Keywords -->
          <% if @knowledge.keywords.present? %>
            <div class="flex flex-wrap gap-2 mb-6">
              <% JSON.parse(@knowledge.keywords).each do |keyword| %>
                <span class="px-3 py-1 bg-gradient-to-r from-purple-900/30 to-blue-900/30 border border-purple-500/30 rounded-full text-sm text-purple-300">
                  #<%= keyword %>
                </span>
              <% end %>
            </div>
          <% end %>
        
          <!-- Thumbnail -->
          <% if @knowledge.thumbnail_url.present? %>
            <div class="relative group mb-8">
              <div class="absolute inset-0 bg-gradient-to-r from-purple-600/20 to-blue-600/20 rounded-2xl blur-xl opacity-0 group-hover:opacity-100 transition duration-300"></div>
              <img src="<%= @knowledge.thumbnail_url %>" class="relative w-full rounded-2xl border border-gray-800" alt="<%= @knowledge.title %>">
            </div>
          <% end %>
        
          <!-- Summary -->
          <div class="bg-gradient-to-r from-purple-900/20 to-blue-900/20 border border-purple-500/30 rounded-xl p-6 mb-8">
            <h2 class="text-lg font-semibold text-white mb-3 flex items-center gap-2">
              <span class="text-purple-400">📝</span>
              Summary
            </h2>
            <p class="text-gray-300 leading-relaxed"><%= @knowledge.summary %></p>
          </div>
        
          <!-- Original URL -->
          <div class="mb-8">
            <h2 class="text-lg font-semibold text-white mb-3 flex items-center gap-2">
              <span class="text-blue-400">🔗</span>
              Original URL
            </h2>
            <div class="bg-gray-800/50 rounded-xl p-4">
              <%= link_to @knowledge.original_url, @knowledge.original_url, 
                  target: "_blank", 
                  class: "text-blue-400 hover:text-blue-300 break-all transition duration-200" %>
            </div>
          </div>
        
          <!-- Full Content (Collapsible) -->
          <details class="group">
            <summary class="cursor-pointer text-lg font-semibold text-white mb-3 flex items-center gap-2 hover:text-purple-400 transition duration-200">
              <span class="text-gray-400 group-open:text-purple-400">📖</span>
              View Full Content
            </summary>
            <div class="mt-4 p-6 bg-gray-800/30 rounded-xl border border-gray-700">
              <p class="text-gray-300 whitespace-pre-wrap leading-relaxed"><%= @knowledge.content %></p>
            </div>
          </details>
        
        <% elsif @knowledge.status == "failed" %>
          <!-- Failed -->
          <div class="text-center py-16">
            <div class="relative inline-block mb-6">
              <div class="absolute inset-0 bg-gradient-to-r from-red-600 to-orange-600 rounded-full blur-xl opacity-50"></div>
              <div class="relative text-6xl">❌</div>
            </div>
            <h2 class="text-2xl font-semibold bg-gradient-to-r from-red-400 to-orange-400 bg-clip-text text-transparent mb-3">
              Processing Failed
            </h2>
            <% if @knowledge.error_message.present? %>
              <div class="bg-red-900/20 border border-red-500/30 rounded-xl p-4 mb-6 max-w-2xl mx-auto">
                <p class="text-red-300 text-sm">
                  <%= @knowledge.error_message %>
                </p>
              </div>
            <% end %>
            <p class="text-gray-400 mb-6">
              An error occurred while processing the content.
            </p>
            <%= form_with url: retry_knowledge_path(@knowledge), method: :post, local: false, class: "inline-block" do |f| %>
              <%= f.submit "Retry", class: "px-6 py-3 bg-gradient-to-r from-purple-600 to-blue-600 text-white rounded-xl hover:from-purple-700 hover:to-blue-700 transition duration-200 cursor-pointer" %>
            <% end %>
          </div>
        <% else %>
          <!-- Processing -->
          <div class="text-center py-16">
            <div class="relative inline-block mb-6">
              <div class="absolute inset-0 bg-gradient-to-r from-purple-600 to-blue-600 rounded-full blur-xl opacity-50 animate-pulse"></div>
              <div class="relative animate-spin h-16 w-16 border-4 border-purple-500 rounded-full border-t-transparent"></div>
            </div>
            <h2 class="text-2xl font-semibold bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent mb-3">
              Processing...
            </h2>
            <p class="text-gray-400">
              Analyzing content. Please wait a moment.
            </p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
