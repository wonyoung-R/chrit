<div class="group">
  <%= link_to knowledge_path(knowledge),
      class: "block px-4 py-3 text-sm text-gray-600 hover:text-gray-900 hover:bg-white rounded-lg transition-all",
      data: { turbo_frame: "_top" } do %>
    <div class="flex items-center justify-between">
      <span class="truncate flex-1">
        <% if knowledge.completed? %>
          <%= knowledge.title || knowledge.original_url %>
        <% else %>
          <span class="text-gray-400">Processing...</span>
        <% end %>
      </span>
      <span class="text-xs text-gray-400 ml-4">
        <%= time_ago_in_words(knowledge.created_at) %> ago
      </span>
    </div>
  <% end %>
</div>