<div class="min-h-screen bg-gray-950 text-white">
  <%= render 'shared/admin_navbar' %>

  <!-- Main Content -->
  <div class="p-6">
    <!-- Stats Grid -->
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4 mb-8">
      <!-- Total Users Card -->
      <div class="rounded-lg border border-gray-700 bg-gray-900 p-6 shadow-lg hover:shadow-xl transition-shadow">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-400">전체 사용자</p>
            <p class="text-2xl font-bold"><%= number_with_delimiter(@total_users) %></p>
            <p class="text-xs text-green-400 mt-1">+<%= @today_users %> 오늘</p>
          </div>
          <div class="h-12 w-12 rounded-lg bg-blue-600/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
          </div>
        </div>
      </div>

      <!-- Total Knowledge Card -->
      <div class="rounded-lg border border-gray-700 bg-gray-900 p-6 shadow-lg hover:shadow-xl transition-shadow">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-400">전체 콘텐츠</p>
            <p class="text-2xl font-bold"><%= number_with_delimiter(@total_knowledges) %></p>
            <p class="text-xs text-green-400 mt-1">+<%= @today_knowledges %> 오늘</p>
          </div>
          <div class="h-12 w-12 rounded-lg bg-purple-600/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
        </div>
      </div>

      <!-- Active Subscriptions Card -->
      <div class="rounded-lg border border-gray-700 bg-gray-900 p-6 shadow-lg hover:shadow-xl transition-shadow">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-400">활성 구독</p>
            <p class="text-2xl font-bold"><%= @active_subscriptions %></p>
            <p class="text-xs text-gray-400 mt-1">전체 <%= @total_subscriptions %>개</p>
          </div>
          <div class="h-12 w-12 rounded-lg bg-green-600/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
        </div>
      </div>

      <!-- Monthly Revenue Card -->
      <div class="rounded-lg border border-gray-700 bg-gray-900 p-6 shadow-lg hover:shadow-xl transition-shadow">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-400">이번 달 수익</p>
            <p class="text-2xl font-bold">₩<%= number_with_delimiter(@monthly_revenue.to_i) %></p>
            <p class="text-xs text-green-400 mt-1">+₩<%= number_with_delimiter(@today_revenue.to_i) %> 오늘</p>
          </div>
          <div class="h-12 w-12 rounded-lg bg-yellow-600/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Charts Row -->
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3 mb-8">
      <!-- Plan Distribution -->
      <div class="rounded-lg border border-gray-800 bg-gray-900/50 p-6">
        <h3 class="text-lg font-semibold mb-4">플랜별 사용자</h3>
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-400">Free</span>
            <span class="text-sm font-medium"><%= @plan_distribution[:free] %>명</span>
          </div>
          <div class="w-full bg-gray-800 rounded-full h-2">
            <div class="bg-gray-500 h-2 rounded-full" style="width: <%= (@plan_distribution[:free].to_f / @total_users * 100).round %>%"></div>
          </div>
          
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-400">Pro</span>
            <span class="text-sm font-medium"><%= @plan_distribution[:pro] %>명</span>
          </div>
          <div class="w-full bg-gray-800 rounded-full h-2">
            <div class="bg-purple-500 h-2 rounded-full" style="width: <%= (@plan_distribution[:pro].to_f / @total_users * 100).round %>%"></div>
          </div>
          
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-400">Business</span>
            <span class="text-sm font-medium"><%= @plan_distribution[:business] %>명</span>
          </div>
          <div class="w-full bg-gray-800 rounded-full h-2">
            <div class="bg-blue-500 h-2 rounded-full" style="width: <%= (@plan_distribution[:business].to_f / @total_users * 100).round %>%"></div>
          </div>
        </div>
      </div>

      <!-- Content Type Distribution -->
      <div class="rounded-lg border border-gray-800 bg-gray-900/50 p-6">
        <h3 class="text-lg font-semibold mb-4">콘텐츠 타입</h3>
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-400">YouTube</span>
            <span class="text-sm font-medium"><%= @content_distribution[:youtube] %>개</span>
          </div>
          <div class="w-full bg-gray-800 rounded-full h-2">
            <div class="bg-red-500 h-2 rounded-full" style="width: <%= (@content_distribution[:youtube].to_f / @total_knowledges * 100).round %>%"></div>
          </div>
          
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-400">Article</span>
            <span class="text-sm font-medium"><%= @content_distribution[:article] %>개</span>
          </div>
          <div class="w-full bg-gray-800 rounded-full h-2">
            <div class="bg-green-500 h-2 rounded-full" style="width: <%= (@content_distribution[:article].to_f / @total_knowledges * 100).round %>%"></div>
          </div>
          
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-400">Thread</span>
            <span class="text-sm font-medium"><%= @content_distribution[:thread] %>개</span>
          </div>
          <div class="w-full bg-gray-800 rounded-full h-2">
            <div class="bg-blue-500 h-2 rounded-full" style="width: <%= (@content_distribution[:thread].to_f / @total_knowledges * 100).round %>%"></div>
          </div>
        </div>
      </div>

      <!-- Processing Status -->
      <div class="rounded-lg border border-gray-800 bg-gray-900/50 p-6">
        <h3 class="text-lg font-semibold mb-4">처리 상태</h3>
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-400">완료</span>
            <span class="text-sm font-medium text-green-400"><%= @processing_status[:completed] %>개</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-400">처리중</span>
            <span class="text-sm font-medium text-yellow-400"><%= @processing_status[:processing] %>개</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-400">실패</span>
            <span class="text-sm font-medium text-red-400"><%= @processing_status[:failed] %>개</span>
          </div>
          
          <div class="pt-3 border-t border-gray-800">
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-400">평균 크레딧 사용</span>
              <span class="text-sm font-medium"><%= @average_credits_per_user %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-400">총 크레딧 사용</span>
              <span class="text-sm font-medium"><%= number_with_delimiter(@total_credits_used) %></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tables Row -->
    <div class="grid gap-4 lg:grid-cols-2">
      <!-- Recent Users -->
      <div class="rounded-lg border border-gray-800 bg-gray-900/50 p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-semibold">최근 가입 사용자</h3>
          <%= link_to "전체 보기 →", admin_users_path, class: "text-sm text-blue-400 hover:text-blue-300" %>
        </div>
        <div class="space-y-2">
          <% @recent_users.each do |user| %>
            <div class="flex items-center justify-between py-2 border-b border-gray-800 last:border-0">
              <div>
                <p class="text-sm font-medium"><%= user.email %></p>
                <p class="text-xs text-gray-400"><%= user.created_at.strftime("%Y-%m-%d %H:%M") %></p>
              </div>
              <span class="text-xs px-2 py-1 rounded-full <%= user.user_setting&.plan_type == 'pro' ? 'bg-purple-900/50 text-purple-400' : 'bg-gray-800 text-gray-400' %>">
                <%= user.user_setting&.plan_type&.capitalize || 'Free' %>
              </span>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Recent Knowledge -->
      <div class="rounded-lg border border-gray-800 bg-gray-900/50 p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-semibold">최근 처리된 콘텐츠</h3>
          <%= link_to "전체 보기 →", admin_knowledges_path, class: "text-sm text-blue-400 hover:text-blue-300" %>
        </div>
        <div class="space-y-2">
          <% @recent_knowledges.each do |knowledge| %>
            <div class="flex items-center justify-between py-2 border-b border-gray-800 last:border-0">
              <div class="flex-1 mr-2">
                <p class="text-sm font-medium truncate"><%= knowledge.title || "제목 없음" %></p>
                <p class="text-xs text-gray-400"><%= knowledge.user.email %> • <%= knowledge.created_at.strftime("%m/%d %H:%M") %></p>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-xs px-2 py-1 rounded-full <%= knowledge.content_type == 'youtube' ? 'bg-red-900/50 text-red-400' : 'bg-green-900/50 text-green-400' %>">
                  <%= knowledge.content_type %>
                </span>
                <span class="text-xs px-2 py-1 rounded-full <%= knowledge.status == 'completed' ? 'bg-green-900/50 text-green-400' : knowledge.status == 'failed' ? 'bg-red-900/50 text-red-400' : 'bg-yellow-900/50 text-yellow-400' %>">
                  <%= knowledge.status %>
                </span>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Error Logs -->
    <% if @recent_failures.any? %>
      <div class="mt-8 rounded-lg border border-red-900/50 bg-red-950/30 p-6">
        <h3 class="text-lg font-semibold text-red-400 mb-4">최근 실패한 작업</h3>
        <div class="space-y-2">
          <% @recent_failures.each do |failure| %>
            <div class="p-3 bg-gray-900/50 rounded border border-gray-800">
              <div class="flex items-start justify-between">
                <div>
                  <p class="text-sm font-medium"><%= failure.original_url %></p>
                  <p class="text-xs text-gray-400">사용자: <%= failure.user.email %> • <%= failure.updated_at.strftime("%Y-%m-%d %H:%M") %></p>
                  <p class="text-xs text-red-400 mt-1"><%= failure.error_message %></p>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>