<div class="min-h-screen bg-gray-950 text-white">
  <%= render 'shared/admin_navbar' %>

  <!-- Main Content -->
  <div class="p-6">
    <div class="mb-6">
      <h2 class="text-2xl font-bold mb-2">구독 관리</h2>
      <p class="text-gray-400">모든 구독 내역을 조회하고 관리합니다.</p>
    </div>

    <!-- Filters -->
    <div class="mb-6 flex gap-4">
      <%= form_with url: admin_subscriptions_path, method: :get, class: "flex gap-4" do |f| %>
        <%= f.select :status, options_for_select([['전체 상태', ''], ['활성', 'active'], ['대기', 'pending'], ['만료', 'expired'], ['취소', 'cancelled'], ['실패', 'failed']], params[:status]),
            {}, class: "px-4 py-2 bg-gray-900 border border-gray-800 rounded-lg text-white focus:outline-none focus:border-purple-500" %>
        
        <%= f.select :plan, options_for_select([['전체 플랜', ''], ['Pro', 'pro'], ['Business', 'business']], params[:plan]),
            {}, class: "px-4 py-2 bg-gray-900 border border-gray-800 rounded-lg text-white focus:outline-none focus:border-purple-500" %>
        
        <%= f.submit "필터", class: "px-6 py-2 bg-purple-600 hover:bg-purple-700 rounded-lg transition cursor-pointer" %>
      <% end %>
    </div>

    <!-- Subscriptions Table -->
    <div class="rounded-lg border border-gray-700 bg-gray-900 overflow-hidden shadow-lg">
      <table class="w-full">
        <thead class="bg-gray-800 border-b border-gray-700">
          <tr>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-400">ID</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-400">사용자</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-400">플랜</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-400">상태</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-400">금액</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-400">결제 방법</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-400">시작일</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-400">만료일</th>
            <th class="text-center px-6 py-3 text-sm font-medium text-gray-400">주문 ID</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <% @subscriptions.each do |subscription| %>
            <tr class="hover:bg-gray-900/50 transition">
              <td class="px-6 py-4 text-sm"><%= subscription.id %></td>
              <td class="px-6 py-4 text-sm font-medium">
                <%= subscription.user.email %>
              </td>
              <td class="px-6 py-4 text-sm">
                <span class="px-2 py-1 text-xs rounded-full <%= subscription.plan_type == 'pro' ? 'bg-purple-900/50 text-purple-400' : 'bg-blue-900/50 text-blue-400' %>">
                  <%= subscription.plan_type&.capitalize %>
                </span>
              </td>
              <td class="px-6 py-4 text-sm">
                <span class="px-2 py-1 text-xs rounded-full <%= 
                  case subscription.status
                  when 'active' then 'bg-green-900/50 text-green-400'
                  when 'pending' then 'bg-yellow-900/50 text-yellow-400'
                  when 'expired' then 'bg-gray-700 text-gray-400'
                  when 'cancelled' then 'bg-orange-900/50 text-orange-400'
                  when 'failed' then 'bg-red-900/50 text-red-400'
                  else 'bg-gray-800 text-gray-400'
                  end
                %>">
                  <%= subscription.status %>
                </span>
              </td>
              <td class="px-6 py-4 text-sm">
                <% if subscription.amount.present? %>
                  ₩<%= number_with_delimiter(subscription.amount.to_i) %>
                <% else %>
                  <span class="text-gray-500">-</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-400">
                <%= subscription.payment_method || '-' %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-400">
                <%= subscription.started_at&.strftime("%Y-%m-%d") || '-' %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-400">
                <%= subscription.expires_at&.strftime("%Y-%m-%d") || '-' %>
              </td>
              <td class="px-6 py-4 text-sm text-center">
                <% if subscription.toss_order_id.present? %>
                  <span class="text-xs text-gray-500" title="<%= subscription.toss_order_id %>">
                    <%= subscription.toss_order_id.truncate(20) %>
                  </span>
                <% else %>
                  <span class="text-gray-500">-</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if @subscriptions.respond_to?(:current_page) %>
      <div class="mt-6 flex justify-center">
        <%= paginate @subscriptions %>
      </div>
    <% end %>
  </div>
</div>