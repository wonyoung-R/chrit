<div class="min-h-screen bg-gray-950 text-white">
  <%= render 'shared/admin_navbar' %>

  <!-- Main Content -->
  <div class="p-6">
    <div class="mb-6">
      <h2 class="text-2xl font-bold mb-2">콘텐츠 관리</h2>
      <p class="text-gray-400">처리된 모든 콘텐츠를 조회하고 관리합니다.</p>
    </div>

    <!-- Filters -->
    <div class="mb-6 flex gap-4">
      <%= form_with url: admin_knowledges_path, method: :get, class: "flex gap-4" do |f| %>
        <%= f.select :status, options_for_select([['전체 상태', ''], ['완료', 'completed'], ['처리중', 'processing'], ['실패', 'failed']], params[:status]),
            {}, class: "px-4 py-2 bg-gray-900 border border-gray-800 rounded-lg text-white focus:outline-none focus:border-purple-500" %>
        
        <%= f.select :content_type, options_for_select([['전체 타입', ''], ['YouTube', 'youtube'], ['Article', 'article'], ['Thread', 'thread']], params[:content_type]),
            {}, class: "px-4 py-2 bg-gray-900 border border-gray-800 rounded-lg text-white focus:outline-none focus:border-purple-500" %>
        
        <%= f.date_field :date_from, value: params[:date_from], 
            class: "px-4 py-2 bg-gray-900 border border-gray-800 rounded-lg text-white focus:outline-none focus:border-purple-500" %>
        
        <%= f.date_field :date_to, value: params[:date_to],
            class: "px-4 py-2 bg-gray-900 border border-gray-800 rounded-lg text-white focus:outline-none focus:border-purple-500" %>
        
        <%= f.submit "필터", class: "px-6 py-2 bg-purple-600 hover:bg-purple-700 rounded-lg transition cursor-pointer" %>
      <% end %>
    </div>

    <!-- Knowledges Table -->
    <div class="rounded-lg border border-gray-700 bg-gray-900 overflow-hidden shadow-lg">
      <table class="w-full">
        <thead class="bg-gray-800 border-b border-gray-700">
          <tr>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-400">ID</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-400">제목</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-400">사용자</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-400">타입</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-400">상태</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-400">토큰</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-400">크레딧</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-400">생성일</th>
            <th class="text-center px-6 py-3 text-sm font-medium text-gray-400">작업</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <% @knowledges.each do |knowledge| %>
            <tr class="hover:bg-gray-900/50 transition">
              <td class="px-6 py-4 text-sm"><%= knowledge.id %></td>
              <td class="px-6 py-4 text-sm font-medium">
                <div class="max-w-xs truncate" title="<%= knowledge.title %>">
                  <%= knowledge.title || "제목 없음" %>
                </div>
                <% if knowledge.original_url.present? %>
                  <div class="text-xs text-gray-500 truncate max-w-xs" title="<%= knowledge.original_url %>">
                    <%= knowledge.original_url %>
                  </div>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-400">
                <%= knowledge.user.email %>
              </td>
              <td class="px-6 py-4 text-sm">
                <span class="px-2 py-1 text-xs rounded-full <%= knowledge.content_type == 'youtube' ? 'bg-red-900/50 text-red-400' : knowledge.content_type == 'article' ? 'bg-green-900/50 text-green-400' : 'bg-blue-900/50 text-blue-400' %>">
                  <%= knowledge.content_type %>
                </span>
              </td>
              <td class="px-6 py-4 text-sm">
                <span class="px-2 py-1 text-xs rounded-full <%= knowledge.status == 'completed' ? 'bg-green-900/50 text-green-400' : knowledge.status == 'failed' ? 'bg-red-900/50 text-red-400' : 'bg-yellow-900/50 text-yellow-400' %>">
                  <%= knowledge.status %>
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-gray-400">
                <% if knowledge.input_tokens.present? || knowledge.output_tokens.present? %>
                  <div class="text-xs">
                    In: <%= number_with_delimiter(knowledge.input_tokens || 0) %>
                  </div>
                  <div class="text-xs">
                    Out: <%= number_with_delimiter(knowledge.output_tokens || 0) %>
                  </div>
                <% else %>
                  <span class="text-gray-500">-</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm">
                <% if knowledge.credits_consumed.present? %>
                  <span class="font-medium"><%= knowledge.credits_consumed %></span>
                <% else %>
                  <span class="text-gray-500">-</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-400">
                <%= knowledge.created_at.strftime("%m/%d %H:%M") %>
              </td>
              <td class="px-6 py-4 text-sm text-center">
                <% if knowledge.status == 'failed' && knowledge.error_message.present? %>
                  <button type="button" class="text-red-400 hover:text-red-300" 
                          onclick="alert('<%= j(knowledge.error_message) %>')">
                    에러 보기
                  </button>
                <% else %>
                  <span class="text-gray-500">-</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if @knowledges.respond_to?(:current_page) %>
      <div class="mt-6 flex justify-center">
        <%= paginate @knowledges %>
      </div>
    <% end %>
  </div>
</div>