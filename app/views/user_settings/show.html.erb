<div class="min-h-screen bg-black text-white flex flex-col relative overflow-hidden">
  
  <!-- Background Effects -->
  <div class="absolute inset-0 bg-gradient-to-br from-purple-900/20 via-black to-blue-900/20"></div>
  <div class="absolute inset-0">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-purple-600/10 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
  </div>
  
  <!-- Navigation -->
  <nav class="relative z-10 flex justify-between items-center p-8">
    <%= link_to root_path, class: "text-2xl font-bold bg-gradient-to-r from-purple-400 to-blue-400 bg-clip-text text-transparent" do %>
      Chrit
    <% end %>
    <div>
      <div class="flex gap-4">
        <%= link_to "대시보드", dashboard_path, class: "px-4 py-2 text-sm text-gray-400 hover:text-white transition duration-200" %>
        <%= link_to "가격", pricing_path, class: "px-4 py-2 text-sm text-gray-400 hover:text-white transition duration-200" %>
        <% if current_user.admin? %>
          <%= link_to "관리자", admin_dashboard_path, class: "px-4 py-2 text-sm text-purple-400 hover:text-purple-300 transition duration-200" %>
        <% end %>
        <%= link_to "로그아웃", destroy_user_session_path, class: "px-4 py-2 text-sm text-gray-400 hover:text-white transition duration-200", data: { turbo_method: :delete } %>
      </div>
    </div>
  </nav>
  
  <!-- Main Content -->
  <div class="flex-1 relative z-10">
    <div class="max-w-4xl mx-auto px-8">
      
      <!-- Page Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent">
          이메일 계정 설정
        </h1>
        <p class="text-gray-400 mt-2">개인 이메일 기반 설정을 관리합니다</p>
      </div>
      
      <!-- Email Verification Status -->
      <div class="bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-xl p-6 mb-6">
        <h2 class="text-xl font-semibold text-white mb-4">이메일 인증 상태</h2>
        
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-400 mb-2">등록된 이메일</p>
            <p class="text-white text-lg"><%= current_user.email %></p>
          </div>
          
          <div class="text-right">
            <% if @user_setting.email_verified %>
              <div class="flex items-center gap-2 text-green-400">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="font-semibold">인증 완료</span>
              </div>
              <p class="text-sm text-gray-400 mt-1">인증일: <%= @user_setting.email_verified_at&.strftime("%Y년 %m월 %d일") %></p>
            <% else %>
              <div class="flex items-center gap-2 text-yellow-400 mb-3">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                </svg>
                <span class="font-semibold">미인증</span>
              </div>
              <%= button_to "인증 이메일 발송", send_verification_email_user_settings_path,
                  method: :post,
                  class: "px-4 py-2 bg-gradient-to-r from-purple-600 to-blue-600 rounded-lg hover:from-purple-700 hover:to-blue-700 transition duration-200" %>
            <% end %>
          </div>
        </div>
      </div>
      
      <!-- Usage Statistics -->
      <div class="bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-xl p-6 mb-6">
        <h2 class="text-xl font-semibold text-white mb-4">이번 달 사용량</h2>
        
        <div class="space-y-4">
          <div>
            <div class="flex justify-between mb-2">
              <span class="text-gray-400">크레딧 사용량</span>
              <span class="text-white font-semibold">
                <%= @user_setting.used_credits %> / <%= @user_setting.monthly_credit_limit %>
              </span>
            </div>
            <div class="w-full bg-gray-800 rounded-full h-3">
              <div class="bg-gradient-to-r from-purple-600 to-blue-600 h-3 rounded-full transition-all duration-300" 
                   style="width: <%= (@user_setting.used_credits.to_f / @user_setting.monthly_credit_limit * 100).round %>%"></div>
            </div>
          </div>
          
          <div class="grid grid-cols-3 gap-4 pt-4 border-t border-gray-800">
            <div class="text-center">
              <p class="text-2xl font-bold text-purple-400"><%= current_user.current_month_usage.urls_processed %></p>
              <p class="text-sm text-gray-400">처리된 URL</p>
            </div>
            <div class="text-center">
              <p class="text-2xl font-bold text-blue-400"><%= current_user.current_month_usage.youtube_count %></p>
              <p class="text-sm text-gray-400">YouTube</p>
            </div>
            <div class="text-center">
              <p class="text-2xl font-bold text-green-400"><%= current_user.current_month_usage.article_count %></p>
              <p class="text-sm text-gray-400">기사</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Settings Form -->
      <div class="bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-xl p-6">
        <h2 class="text-xl font-semibold text-white mb-4">개인 설정</h2>
        
        <%= form_with model: @user_setting, url: user_settings_path, local: true do |f| %>
          <div class="space-y-4">
            
            <!-- Email Notifications -->
            <div class="flex items-center justify-between">
              <div>
                <label class="text-white font-medium">이메일 알림</label>
                <p class="text-sm text-gray-400">크레딧 사용량 및 중요 알림을 받습니다</p>
              </div>
              <%= f.check_box :email_notifications, class: "w-5 h-5 rounded bg-gray-800 border-gray-600 text-purple-600 focus:ring-purple-500" %>
            </div>
            
            <!-- Privacy Mode -->
            <div>
              <label class="text-white font-medium block mb-2">프라이버시 모드</label>
              <%= f.select :privacy_mode, 
                  options_for_select([
                    ['비공개 - 나만 볼 수 있음', 'private'],
                    ['친구 - 친구만 볼 수 있음', 'friends'],
                    ['공개 - 모두가 볼 수 있음', 'public']
                  ], @user_setting.privacy_mode),
                  {},
                  class: "w-full px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-purple-500" %>
            </div>
            
            <!-- Language -->
            <div>
              <label class="text-white font-medium block mb-2">언어</label>
              <%= f.select :language,
                  options_for_select([
                    ['한국어', 'ko'],
                    ['English', 'en'],
                    ['日本語', 'ja'],
                    ['中文', 'zh']
                  ], @user_setting.language),
                  {},
                  class: "w-full px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-purple-500" %>
            </div>
            
            <!-- Theme -->
            <div>
              <label class="text-white font-medium block mb-2">테마</label>
              <%= f.select :theme,
                  options_for_select([
                    ['다크 모드', 'dark'],
                    ['라이트 모드', 'light']
                  ], @user_setting.theme),
                  {},
                  class: "w-full px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-purple-500" %>
            </div>
            
            <!-- Monthly Credit Limit (admin only or premium users) -->
            <div>
              <label class="text-white font-medium block mb-2">월간 크레딧 한도</label>
              <input type="number" value="<%= @user_setting.monthly_credit_limit %>" disabled
                     class="w-full px-4 py-2 bg-gray-800/50 border border-gray-700 rounded-lg text-gray-400 cursor-not-allowed" />
              <p class="text-sm text-gray-400 mt-1">프리미엄 플랜에서 변경 가능합니다</p>
            </div>
            
            <!-- Submit Button -->
            <div class="pt-4">
              <%= f.submit "설정 저장", 
                  class: "w-full px-6 py-3 bg-gradient-to-r from-purple-600 to-blue-600 rounded-lg hover:from-purple-700 hover:to-blue-700 transition duration-200 font-medium cursor-pointer" %>
            </div>
          </div>
        <% end %>
      </div>
      
    </div>
  </div>
</div>