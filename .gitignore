# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore bundler config.
/.bundle

# Ignore all environment files (they contain secrets).
/.env*
.env
.env.local
.env.production

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore database configuration
/config/database.yml.local

# Ignore node_modules
/node_modules

# Ignore yarn files
/yarn-error.log
yarn-debug.log*
.yarn-integrity

# Ignore Mac system files
.DS_Store
*.swp
*.swo

# Ignore RubyMine/IntelliJ
.idea/

# Ignore VS Code
.vscode/

# Ignore test coverage
/coverage/

# Ignore vendor bundle
/vendor/bundle/

# Ignore spring files
/spring/*.pid

# Ignore uploaded files
/public/uploads

# Ignore precompiled assets
/public/packs
/public/packs-test

# Ignore byebug history
.byebug_history

# Ignore credentials
/config/credentials.yml.enc
/config/credentials/*.key

# Ignore local config overrides
/config/settings.local.yml
/config/settings/*.local.yml
/config/environments/*.local.yml